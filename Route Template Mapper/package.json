{
  "name": "route-template-mapper",
  "productName": "Route Template Mapper",
  "private": true,
  "version": "1.0.0",
  "description": "Read a map JSON, match its navigation graphs to route templates, edit templates & mappings, and export one route-template file per graph.",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "start": "electron .",
    "package": "electron-packager . \"Route Template Mapper\" --platform=win32 --arch=x64 --out=release --overwrite --asar --icon=build/icon.ico --app-version=1.0.0 --ignore=\"node_modules\" --ignore=\"/test\" --ignore=\"/release\""
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "@electron/packager": "^18.3.3"
  }
}
