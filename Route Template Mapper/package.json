{
  "name": "route-template-mapper",
  "productName": "Route Template Mapper",
  "private": true,
  "version": "1.1.1",
  "description": "Read a map JSON, match its navigation graphs to route templates, edit templates & mappings, and export one route-template file per graph.",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "start": "electron .",
    "package": "electron-packager . \"Route Template Mapper\" --platform=win32 --arch=x64 --out=release --overwrite --asar --icon=build/icon.ico --ignore=\"node_modules\" --ignore=\"/test\" --ignore=\"/release\"",
    "package:mac": "electron-packager . \"Route Template Mapper\" --platform=darwin --arch=arm64,x64 --out=release --overwrite --asar --icon=build/icon.icns --app-bundle-id=com.apollosrgb.route-template-mapper --ignore=\"node_modules\" --ignore=\"/test\" --ignore=\"/release\""
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "@electron/packager": "^18.3.3"
  }
}
